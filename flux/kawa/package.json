{
  "name": "kawa",
  "version": "0.1.0",
  "description": "Conversational coding agent accessible through SimpleX Chat",
  "type": "module",
  "main": "dist/kawa.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/kawa.js",
    "dev": "tsc --watch",
    "check": "biome check src/",
    "check:all": "tsc --noEmit && biome check src/ tests/",
    "format": "biome format --write src/",
    "test": "vitest run --exclude tests/e2e",
    "smoke": "vitest run --config vitest.e2e.config.ts",
    "clean": "bash scripts/clean.sh",
    "kawa:check": "bash scripts/check.sh",
    "kawa:start": "bash scripts/start.sh",
    "kawa:stop": "bash scripts/stop.sh"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.68.0",
    "@simplex-chat/types": "^0.4.0",
    "simplex-chat": "^0.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
